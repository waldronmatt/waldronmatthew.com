{
  "name": "waldronmatthew.com",
  "version": "1.0.0",
  "description": "The code for my personal portfolio website.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldronmatt/waldronmatthew.com.git"
  },
  "homepage": "https://www.waldronmatthew.com",
  "scripts": {
    "dev": "run-s webpack-prebuild-dev webpack-dev render-page-dev serve",
    "build": "run-s webpack-prebuild-prod webpack-prod render-page-prod",
    "rebuild": "run-s webpack-prebuild-dev webpack-dev render-page-dev",
    "webpack-prebuild-dev": "webpack --config ./scripts/webpack/env/webpack.dev.prebuild.js",
    "webpack-prebuild-prod": "webpack --config  ./scripts/webpack/env/webpack.prod.prebuild.js",
    "webpack-dev": "webpack --config ./scripts/webpack/env/webpack.dev.js",
    "webpack-prod": "webpack --config ./scripts/webpack/env/webpack.prod.js",
    "render-page-dev": "node ./scripts/render/page.dev.js",
    "render-page-prod": "node ./scripts/render/page.prod.js",
    "serve": "node ./scripts/browsersync"
  },
  "keywords": [
    "potfolio",
    "bowman",
    "static site generator",
    "nodejs",
    "webpack",
    "browsersync"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "sideEffects": true,
  "author": "Matthew Waldron (https://www.waldronmatthew.com)",
  "license": "MIT (Source Code)",
  "devDependencies": {
    "@babel/eslint-parser": "^7.12.1",
    "@babel/plugin-transform-runtime": "^7.9.6",
    "@babel/preset-env": "^7.9.6",
    "@node-minify/core": "^5.3.0",
