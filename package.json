    "css-loader": "^3.5.3",
    "ejs": "^3.1.2",
    "eslint": "^7.11.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-webpack-plugin": "^2.2.1",
    "favicons-webpack-plugin": "^4.2.0",
    "front-matter": "^3.1.0",
