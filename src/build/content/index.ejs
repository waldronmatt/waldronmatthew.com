---
template: basic
---

<h1><%= data.header %></h1>
<div id="type-container" data-load="index">
  <div class="typewriter">
    <h2><%= data.description %></h2>
  </div>
</div>

<div class="grid" id="projects">
  <% data.pictures.forEach((el) => { %>
    <div class="<%= data.class %>" style="background-image: url('<%= site.assetsManifest[`static/images/${el.picture}`] %>');">
      <a href="<%= site.basePath %>projects/<%= el.url %>" class="grid-link">
        <div class="tile">
          <p><%= el.title %></p>
        </div>
      </a>
    </div>
  <% }) %>
</div>

<div class="btn-container">
  <div class="pages">
    <div class="list" id="loadMore"><button ><%= data.button %></button></div>
  </div>
</div>